---
import MainLayout from "../layouts/MainLayout.astro";

const projects = [
  {
    category: "Business Branding",
    title: "Premium Metal Business Cards",
    description:
      "Durable engraved cards designed to make a strong first impression.",
  },
  {
    category: "Promotional Products",
    title: "Custom Bamboo Stylus Pens",
    description:
      "Professional branded pens created for businesses, events, and client gifts.",
  },
  {
    category: "Personalized Gifts",
    title: "Engraved Glassware",
    description:
      "Custom glass pieces made for weddings, celebrations, and keepsakes.",
  },
  {
    category: "Leather Goods",
    title: "Personalized Leather Accessories",
    description:
      "Clean, lasting engraving on keychains, sleeves, tags, and other leather pieces.",
  },
  {
    category: "Corporate Gifts",
    title: "Branded Client Gifts",
    description:
      "Thoughtful products designed to represent a business with care and quality.",
  },
  {
    category: "Special Projects",
    title: "One-of-a-Kind Engravings",
    description:
      "Custom work created around unique materials, ideas, and occasions.",
  },
];
---

<MainLayout
  title="Portfolio"
  description="Explore custom engraved pens, metal business cards, glassware, leather goods, and personalized gifts."
>
  <main>
    <section class="portfolio-hero">
      <p class="eyebrow">Selected work</p>

      <h1>Made to be noticed. Designed to be remembered.</h1>

      <p class="intro">
        Explore custom engraving created for businesses, events, gifts, and
        meaningful moments.
      </p>
    </section>

    <section class="portfolio-grid">
      {
        projects.map((project, index) => (
          <article class:list={["project-card", index === 0 && "featured-card"]}>
            <div class="image-placeholder">
              <span>Project photography coming soon</span>
            </div>

            <div class="project-copy">
              <p class="category">{project.category}</p>
              <h2>{project.title}</h2>
              <p class="description">{project.description}</p>
            </div>
          </article>
        ))
      }
    </section>

    <section class="portfolio-cta">
      <p class="eyebrow">Your idea could be next</p>
      <h2>Let’s create something distinctive.</h2>

      <a href="/quote">Request a Quote</a>
    </section>
  </main>
</MainLayout>

<style>
  .portfolio-hero {
    max-width: 1250px;
    margin: 0 auto;
    padding: 8rem 5% 6rem;
    text-align: center;
  }

  .eyebrow,
  .category {
    margin: 0 0 1rem;
    color: #777777;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 1050px;
    margin: 0 auto;
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 720px;
    margin: 2rem auto 0;
    color: #666666;
    font-size: 1.2rem;
    line-height: 1.7;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 5% 9rem;
  }

  .project-card {
    overflow: hidden;
    border-radius: 30px;
    background: #f5f5f7;
  }

  .featured-card {
    grid-column: 1 / -1;
  }

  .image-placeholder {
    display: grid;
    place-items: center;
    min-height: 480px;
    background: linear-gradient(145deg, #ededed, #d9d9d9);
    color: #888888;
    text-align: center;
  }

  .featured-card .image-placeholder {
    min-height: 650px;
    background:
      radial-gradient(circle at top right, #3a3a3a, #151515 60%);
    color: #8f8f8f;
  }

  .project-copy {
    padding: 2rem;
  }

  .project-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .description {
    margin: 1.25rem 0 0;
    color: #666666;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .portfolio-cta {
    padding: 9rem 5%;
    background: #111111;
    color: #ffffff;
    text-align: center;
  }

  .portfolio-cta .eyebrow {
    color: #a0a0a0;
  }

  .portfolio-cta h2 {
    max-width: 900px;
    margin: 0 auto;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .portfolio-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    margin-top: 2.5rem;
    padding: 0 1.5rem;
    border-radius: 999px;
    background: #ffffff;
    color: #111111;
    font-weight: 700;
    text-decoration: none;
  }

  .portfolio-cta a:hover {
    background: #e8e8e8;
  }

  @media (max-width: 800px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }

    .featured-card {
      grid-column: auto;
    }

    .image-placeholder,
    .featured-card .image-placeholder {
      min-height: 380px;
    }
  }
</style>