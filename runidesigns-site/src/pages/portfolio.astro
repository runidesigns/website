---
import MainLayout from "../layouts/MainLayout.astro";

const projects = [
  {
    category: "Business Branding",
    title: "Premium Metal Business Cards",
    description:
      "Durable engraved metal cards designed to make a strong and memorable first impression.",
    image: "/images/products/metal-business-cards.jpg",
    alt: "Custom engraved metal business cards by Runi Designs",
  },
  {
    category: "Promotional Products",
    title: "Custom Bamboo Stylus Pens",
    description:
      "Professional branded pens created for businesses, events, trade shows, and client gifts.",
    image: "/images/products/bamboo-pens.jpg",
    alt: "Custom engraved bamboo stylus pens by Runi Designs",
  },
  {
    category: "Leather Goods",
    title: "Personalized Leather Keychains",
    description:
      "Clean, lasting personalization on leather keychains made for gifts, events, and business branding.",
    image: "/images/products/leather-keychains.jpg",
    alt: "Personalized engraved leather keychains by Runi Designs",
  },
  {
    category: "Personalized Gifts",
    title: "Custom Stone Coasters",
    description:
      "Engraved stone coasters created for homes, celebrations, gifts, and special occasions.",
    image: "/images/products/stone-coasters.jpg",
    alt: "Custom engraved stone coasters by Runi Designs",
  },
];
---

<MainLayout
  title="Our Work"
  description="Explore custom engraved metal business cards, bamboo pens, leather keychains, stone coasters, and personalized products by Runi Designs."
>
  <main>
    <section class="portfolio-hero">
      <p class="eyebrow">Selected work</p>

      <h1>Made to be noticed. Designed to be remembered.</h1>

      <p class="intro">
        Explore custom engraving created for businesses, events, gifts, and
        meaningful moments.
      </p>
    </section>

    <section class="portfolio-grid">
      {
        projects.map((project, index) => (
          <article class:list={["project-card", index === 0 && "featured-card"]}>
            <div class="project-image">
              <img
                src={project.image}
                alt={project.alt}
                loading={index === 0 ? "eager" : "lazy"}
              />
            </div>

            <div class="project-copy">
              <p class="category">{project.category}</p>
              <h2>{project.title}</h2>
              <p class="description">{project.description}</p>
            </div>
          </article>
        ))
      }
    </section>

    <section class="portfolio-cta">
      <p class="eyebrow">Your idea could be next</p>
      <h2>Let’s create something distinctive.</h2>

      <a href="/#quote">Request a Quote</a>
    </section>
  </main>
</MainLayout>

<style>
  .portfolio-hero {
    max-width: 1250px;
    margin: 0 auto;
    padding: 10rem 5% 6rem;
    text-align: center;
  }

  .eyebrow,
  .category {
    margin: 0 0 1rem;
    color: #777777;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 1050px;
    margin: 0 auto;
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 720px;
    margin: 2rem auto 0;
    color: #666666;
    font-size: 1.2rem;
    line-height: 1.7;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 5% 9rem;
  }

  .project-card {
    overflow: hidden;
    border: 1px solid #ebebeb;
    border-radius: 30px;
    background: #f5f5f7;
  }

  .featured-card {
    grid-column: 1 / -1;
  }

  .project-image {
    height: 480px;
    overflow: hidden;
    background: #e8e8e8;
  }

  .featured-card .project-image {
    height: 650px;
  }

  .project-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.025);
  }

  .project-copy {
    padding: 2rem;
  }

  .project-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .description {
    max-width: 680px;
    margin: 1.25rem 0 0;
    color: #666666;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .portfolio-cta {
    padding: 9rem 5%;
    background: #111111;
    color: #ffffff;
    text-align: center;
  }

  .portfolio-cta .eyebrow {
    color: #a0a0a0;
  }

  .portfolio-cta h2 {
    max-width: 900px;
    margin: 0 auto;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .portfolio-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    margin-top: 2.5rem;
    padding: 0 1.5rem;
    border-radius: 999px;
    background: #ffffff;
    color: #111111;
    font-weight: 700;
    text-decoration: none;
  }

  .portfolio-cta a:hover {
    background: #e8e8e8;
    transform: translateY(-1px);
  }

  @media (max-width: 800px) {
    .portfolio-hero {
      padding-top: 8rem;
    }

    .portfolio-grid {
      grid-template-columns: 1fr;
    }

    .featured-card {
      grid-column: auto;
    }

    .project-image,
    .featured-card .project-image {
      height: 420px;
    }
  }

  @media (max-width: 560px) {
    .portfolio-hero {
      padding: 7.5rem 20px 4.5rem;
    }

    .portfolio-grid {
      padding: 1rem 20px 6rem;
    }

    .project-image,
    .featured-card .project-image {
      height: 340px;
    }

    .project-copy {
      padding: 1.5rem;
    }
  }
</style>