---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Contact"
  description="Contact Runi Designs to discuss custom laser engraving, business branding, gifts, and special projects."
>
  <main>
    <section class="contact-hero">
      <p class="eyebrow">Contact Runi Designs</p>

      <h1>Let’s bring your idea to life.</h1>

      <p class="intro">
        Have a question, need help choosing a product, or want to discuss a
        custom engraving project? Reach out and we’ll help you get started.
      </p>
    </section>

    <section class="contact-content">
      <div class="contact-card">
        <p class="eyebrow">Get in touch</p>

        <h2>We’d love to hear about your project.</h2>

        <div class="contact-methods">
          <div>
            <span>Email</span>
            <a href="mailto:brian@runidesigns.com">
              brian@runidesigns.com
            </a>
          </div>

          <div>
            <span>Website</span>
            <a href="https://runidesigns.com">
              runidesigns.com
            </a>
          </div>

          <div>
            <span>Location</span>
            <p>Columbus, Ohio</p>
          </div>
        </div>
      </div>

      <div class="project-card">
        <p class="eyebrow">Ready to begin?</p>

        <h2>Request a custom quote.</h2>

        <p>
          Share your product, quantity, artwork, and desired completion date.
          We’ll review everything and follow up with pricing and next steps.
        </p>

        <a class="primary-button" href="/quote">
          Start a Quote Request
        </a>
      </div>
    </section>

    <section class="expectations">
      <div>
        <p class="eyebrow">What happens next</p>
        <h2>A simple, personal process.</h2>
      </div>

      <div class="steps">
        <article>
          <span>01</span>
          <h3>Tell us your idea</h3>
          <p>
            Send the product, quantity, wording, logo, and timeline you have in
            mind.
          </p>
        </article>

        <article>
          <span>02</span>
          <h3>Review your options</h3>
          <p>
            We’ll discuss materials, pricing, availability, and the best
            engraving approach.
          </p>
        </article>

        <article>
          <span>03</span>
          <h3>Approve your design</h3>
          <p>
            You’ll review the details before production begins.
          </p>
        </article>
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .contact-hero {
    max-width: 1150px;
    margin: 0 auto;
    padding: 8rem 5% 5rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: #777777;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 950px;
    margin: 0 auto;
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 720px;
    margin: 2rem auto 0;
    color: #666666;
    font-size: 1.2rem;
    line-height: 1.7;
  }

  .contact-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 5% 8rem;
  }

  .contact-card,
  .project-card {
    min-height: 560px;
    padding: 3rem;
    border-radius: 32px;
  }

  .contact-card {
    background: #f5f5f7;
    color: #111111;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    background: #111111;
    color: #ffffff;
  }

  h2 {
    margin: 0;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .contact-methods {
    display: grid;
    gap: 2rem;
    margin-top: 4rem;
  }

  .contact-methods div {
    display: grid;
    gap: 0.35rem;
  }

  .contact-methods span {
    color: #777777;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact-methods a,
  .contact-methods p {
    margin: 0;
    color: #111111;
    font-size: 1.15rem;
    text-decoration: none;
  }

  .contact-methods a:hover {
    text-decoration: underline;
  }

  .project-card .eyebrow {
    color: #a0a0a0;
  }

  .project-card > p:not(.eyebrow) {
    margin: 2rem 0;
    color: #b8b8b8;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .primary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    margin-top: auto;
    padding: 0 1.5rem;
    border-radius: 999px;
    background: #ffffff;
    color: #111111;
    font-weight: 700;
    text-decoration: none;
  }

  .primary-button:hover {
    background: #e8e8e8;
  }

  .expectations {
    padding: 8rem 5%;
    background: #f5f5f7;
  }

  .expectations > div {
    max-width: 1400px;
    margin-right: auto;
    margin-left: auto;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 4rem;
  }

  .steps article {
    min-height: 280px;
    padding: 2rem;
    border-radius: 28px;
    background: #ffffff;
  }

  .steps span {
    color: #999999;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .steps h3 {
    margin: 5rem 0 1rem;
    font-size: 1.6rem;
    letter-spacing: -0.03em;
  }

  .steps p {
    margin: 0;
    color: #666666;
    line-height: 1.7;
  }

  @media (max-width: 850px) {
    .contact-content,
    .steps {
      grid-template-columns: 1fr;
    }

    .contact-card,
    .project-card {
      min-height: 480px;
      padding: 2rem;
      border-radius: 24px;
    }

    .steps article {
      min-height: 240px;
    }

    .steps h3 {
      margin-top: 4rem;
    }
  }
</style>