---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Request a Quote"
  description="Request pricing for a custom engraving project from Runi Designs."
>
  <main>
    <section class="quote-hero">
      <p class="eyebrow">Request a quote</p>

      <h1>Let’s create something memorable.</h1>

      <p class="intro">
        Tell us about your project, desired quantity, and timeline. We’ll review
        the details and follow up with pricing and next steps.
      </p>
    </section>

    <section class="quote-section">
      <form
        class="quote-form"
        action="mailto:brian@runidesigns.com"
        method="post"
        enctype="text/plain"
      >
        <div class="field-grid">
          <label>
            Full name
            <input type="text" name="Name" required />
          </label>

          <label>
            Email address
            <input type="email" name="Email" required />
          </label>

          <label>
            Phone number
            <input type="tel" name="Phone" />
          </label>

          <label>
            Project type
            <select name="Project type" required>
              <option value="">Select one</option>
              <option>Business branding</option>
              <option>Metal business cards</option>
              <option>Custom pens</option>
              <option>Personalized gift</option>
              <option>Wedding or event item</option>
              <option>Glass engraving</option>
              <option>Leather engraving</option>
              <option>Other</option>
            </select>
          </label>

          <label>
            Estimated quantity
            <input type="number" name="Quantity" min="1" />
          </label>

          <label>
            Desired completion date
            <input type="date" name="Completion date" />
          </label>
        </div>

        <label>
          Tell us about your project
          <textarea
            name="Project details"
            rows="7"
            placeholder="Describe the item, material, wording, logo, dimensions, or any other details."
            required
          ></textarea>
        </label>

        <button type="submit">Submit Quote Request</button>

        <p class="form-note">
          Submitting this form will open your email application with the project
          details included.
        </p>
      </form>
    </section>
  </main>
</MainLayout>

<style>
  .quote-hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 8rem 5% 4rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: #777777;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 950px;
    margin: 0 auto;
    font-size: clamp(3.4rem, 8vw, 7rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 720px;
    margin: 2rem auto 0;
    color: #666666;
    font-size: 1.2rem;
    line-height: 1.7;
  }

  .quote-section {
    padding: 2rem 5% 9rem;
  }

  .quote-form {
    max-width: 950px;
    margin: 0 auto;
    padding: 3rem;
    border-radius: 32px;
    background: #f5f5f7;
  }

  .field-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  label {
    display: grid;
    gap: 0.65rem;
    margin-bottom: 1.5rem;
    color: #222222;
    font-size: 0.95rem;
    font-weight: 600;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid #d4d4d4;
    border-radius: 14px;
    background: #ffffff;
    color: #111111;
    font: inherit;
  }

  input,
  select {
    min-height: 52px;
    padding: 0 1rem;
  }

  textarea {
    padding: 1rem;
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: 2px solid #111111;
    outline-offset: 2px;
  }

  button {
    min-height: 54px;
    padding: 0 1.6rem;
    border: 0;
    border-radius: 999px;
    background: #111111;
    color: #ffffff;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  button:hover {
    background: #2a2a2a;
  }

  .form-note {
    margin: 1rem 0 0;
    color: #777777;
    font-size: 0.85rem;
  }

  @media (max-width: 700px) {
    .quote-hero {
      padding-top: 5rem;
    }

    .field-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .quote-form {
      padding: 1.5rem;
      border-radius: 22px;
    }

    button {
      width: 100%;
    }
  }
</style>