---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="About"
  description="Learn about Runi Designs and our approach to thoughtful design and precision laser engraving."
>
  <main>
    <section class="about-hero">
      <p class="eyebrow">About Runi Designs</p>

      <h1>Thoughtful design. Precise craftsmanship.</h1>

      <p class="intro">
        Runi Designs creates custom engraved products that help businesses stand
        out and make personal moments feel even more meaningful.
      </p>
    </section>

    <section class="story">
      <div class="story-copy">
        <p class="eyebrow">Our story</p>

        <h2>Created to make every detail feel intentional.</h2>

        <p>
          Runi Designs was founded with a focus on turning everyday products
          into memorable, personalized pieces. From business branding and
          promotional products to wedding gifts and keepsakes, every project is
          approached with care and attention to detail.
        </p>

        <p>
          We work with materials such as metal, wood, leather, glass, acrylic,
          and more to create clean, lasting engravings for businesses,
          celebrations, and meaningful moments.
        </p>
      </div>

      <div class="image-placeholder">
        <p>Your workshop or portrait photo will go here.</p>
      </div>
    </section>

    <section class="values">
      <div class="section-heading">
        <p class="eyebrow">What matters to us</p>
        <h2>Premium work without losing the personal touch.</h2>
      </div>

      <div class="value-grid">
        <article>
          <span>01</span>
          <h3>Precision</h3>
          <p>
            Every design is carefully prepared and engraved for a clean,
            professional result.
          </p>
        </article>

        <article>
          <span>02</span>
          <h3>Personal service</h3>
          <p>
            Each project receives individual attention, from the first idea to
            the final product.
          </p>
        </article>

        <article>
          <span>03</span>
          <h3>Memorable design</h3>
          <p>
            We create pieces designed to represent your brand, celebration, or
            story in a lasting way.
          </p>
        </article>
      </div>
    </section>

    <section class="about-cta">
      <p class="eyebrow">Start your project</p>
      <h2>Let’s create something worth remembering.</h2>

      <div class="actions">
        <a class="primary" href="/quote">Request a Quote</a>
        <a class="secondary" href="/#work">View Our Work →</a>
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .about-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8rem 5% 6rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: #777777;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 1000px;
    margin: 0 auto;
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 760px;
    margin: 2rem auto 0;
    color: #666666;
    font-size: 1.2rem;
    line-height: 1.7;
  }

  .story {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: 5rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 7rem 5%;
  }

  .story-copy {
    max-width: 620px;
  }

  h2 {
    margin: 0;
    font-size: clamp(2.8rem, 5vw, 5rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .story-copy p:not(.eyebrow) {
    color: #666666;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .image-placeholder {
    display: grid;
    place-items: center;
    min-height: 620px;
    border-radius: 32px;
    background: linear-gradient(145deg, #efefef, #dcdcdc);
    color: #777777;
    text-align: center;
  }

  .values {
    padding: 8rem 5%;
    background: #111111;
    color: #ffffff;
  }

  .section-heading,
  .value-grid {
    max-width: 1400px;
    margin-right: auto;
    margin-left: auto;
  }

  .section-heading {
    margin-bottom: 4rem;
  }

  .values .eyebrow {
    color: #a0a0a0;
  }

  .value-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .value-grid article {
    min-height: 300px;
    padding: 2rem;
    border: 1px solid #303030;
    border-radius: 28px;
    background: #181818;
  }

  .value-grid span {
    color: #8e8e8e;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .value-grid h3 {
    margin: 6rem 0 1rem;
    font-size: 1.7rem;
  }

  .value-grid p {
    margin: 0;
    color: #b5b5b5;
    line-height: 1.7;
  }

  .about-cta {
    padding: 9rem 5%;
    text-align: center;
  }

  .about-cta h2 {
    max-width: 900px;
    margin: 0 auto;
  }

  .actions {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .primary,
  .secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 1.4rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
  }

  .primary {
    background: #111111;
    color: #ffffff;
  }

  .secondary {
    color: #111111;
  }

  @media (max-width: 850px) {
    .story,
    .value-grid {
      grid-template-columns: 1fr;
    }

    .story {
      gap: 3rem;
      padding-top: 5rem;
      padding-bottom: 5rem;
    }

    .image-placeholder {
      min-height: 420px;
    }

    .value-grid article {
      min-height: 250px;
    }

    .value-grid h3 {
      margin-top: 4rem;
    }
  }
</style>
