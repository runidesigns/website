---
const products = [
  "Metal Business Cards",
  "Bamboo Pens",
  "Leather Goods",
  "Stone Coasters",
  "Custom Glassware",
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <meta
      name="description"
      content="Runi Designs creates premium custom engraved products, business materials, gifts, and keepsakes."
    />

    <title>Runi Designs | Custom Engraving & Personalized Products</title>
  </head>

  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Runi Designs homepage">
  <span class="brand-mark">
    <img src="/images/runi-mark.svg" alt="" />
  </span>

  <span>Runi Designs</span>
</a>

      <nav aria-label="Main navigation">
        <a href="#work">Our Work</a>
        <a href="#services">Services</a>
        <a href="#about">About</a>
      </nav>

      <a class="header-button" href="#quote">Request a Quote</a>
    </header>

    <main>
      <section class="hero">
        <div class="hero-glow hero-glow-one"></div>
        <div class="hero-glow hero-glow-two"></div>

        <div class="hero-content">
          <p class="eyebrow">Custom engraving and personalized design</p>

          <h1>
            Your vision.
            <span>Made unforgettable.</span>
          </h1>

          <p class="hero-description">
            Premium custom products created for businesses, celebrations,
            meaningful gifts, and moments worth remembering.
          </p>

          <div class="hero-actions">
            <a class="primary-button" href="#work">
              Explore Our Work
              <span aria-hidden="true">→</span>
            </a>

            <a class="secondary-button" href="#quote">
              Start a Project
            </a>
          </div>
        </div>

        <div class="product-display" aria-label="Runi Designs product display">
          <div class="display-orbit orbit-one"></div>
          <div class="display-orbit orbit-two"></div>

          <div class="product-card card-back">
            <span>Crafted</span>
          </div>

          <div class="product-card card-main">
            <div class="engraved-mark">R</div>
            <p>Runi Designs</p>
            <small>Designed to leave an impression.</small>
          </div>

          <div class="product-card card-front">
            <span>Personalized</span>
          </div>
        </div>
      </section>

      <section class="product-strip" id="work">
        <p>Made for every occasion</p>

        <div class="product-list">
          {
            products.map((product) => (
              <span>
                {product}
                <i aria-hidden="true"></i>
              </span>
            ))
          }
        </div>
      </section>
    </main>

    <style>
  :root {
    font-family:
      Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #f7f7f5;
    background: #080808;
    font-synthesis: none;
    text-rendering: optimizeLegibility;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    min-width: 320px;
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 70% 25%, #27221c 0%, transparent 28%),
      #080808;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
  position: fixed;
  z-index: 100;
  top: 16px;
  left: 50%;
  transform: translateX(-50%);
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  width: min(calc(100% - 32px), 1320px);
  padding: 12px 14px 12px 18px;
  border: 1px solid rgb(255 255 255 / 12%);
  border-radius: 999px;
  background: rgb(12 12 12 / 68%);
  box-shadow:
    0 16px 50px rgb(0 0 0 / 25%),
    inset 0 1px 0 rgb(255 255 255 / 5%);
  backdrop-filter: blur(24px) saturate(140%);
  -webkit-backdrop-filter: blur(24px) saturate(140%);
}

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    width: fit-content;
    font-size: 15px;
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .brand-mark {
  display: grid;
  place-items: center;
  width: 40px;
  height: 40px;
  overflow: hidden;
  border: 1px solid rgb(255 255 255 / 18%);
  border-radius: 50%;
  background: rgb(255 255 255 / 7%);
  backdrop-filter: blur(12px);
}

.brand-mark img {
  display: block;
  width: 26px;
  height: 26px;
  object-fit: contain;
}  ~\

 nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

nav a {
  padding: 10px 14px;
  border-radius: 999px;
  color: rgb(255 255 255 / 60%);
  font-size: 13px;
  font-weight: 550;
  white-space: nowrap;
  transition:
    color 180ms ease,
    background 180ms ease,
    transform 180ms ease;
}

nav a:hover {
  color: #ffffff;
  background: rgb(255 255 255 / 7%);
  transform: translateY(-1px);
}

  .header-button {
    justify-self: end;
    padding: 11px 18px;
    border: 1px solid rgb(255 255 255 / 18%);
    border-radius: 999px;
    background: rgb(255 255 255 / 7%);
    font-size: 12px;
    font-weight: 600;
    backdrop-filter: blur(16px);
    transition:
      background 180ms ease,
      border-color 180ms ease;
  }

  .header-button:hover {
    border-color: rgb(255 255 255 / 35%);
    background: rgb(255 255 255 / 12%);
  }

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(380px, 0.85fr);
    align-items: center;
    gap: 40px;
    min-height: 100vh;
    padding: 140px clamp(24px, 7vw, 110px) 80px;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    max-width: 780px;
  }

  .eyebrow {
    margin-bottom: 24px;
    color: #c5a77b;
    font-size: 12px;
    font-weight: 650;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 850px;
    font-size: clamp(58px, 7.8vw, 122px);
    font-weight: 580;
    line-height: 0.88;
    letter-spacing: -0.075em;
  }

  h1 span {
    display: block;
    color: rgb(255 255 255 / 38%);
  }

  .hero-description {
    max-width: 620px;
    margin-top: 34px;
    color: rgb(255 255 255 / 59%);
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 40px;
  }

  .primary-button,
  .secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 24px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 650;
    transition:
      transform 200ms ease,
      background 200ms ease;
  }

  .primary-button {
    gap: 24px;
    background: #f4f1eb;
    color: #111111;
  }

  .primary-button:hover,
  .secondary-button:hover {
    transform: translateY(-3px);
  }

  .secondary-button {
    border: 1px solid rgb(255 255 255 / 16%);
    background: rgb(255 255 255 / 5%);
  }

  .product-display {
    position: relative;
    z-index: 2;
    min-height: 600px;
    perspective: 1200px;
  }

  .product-card {
    position: absolute;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    width: min(360px, 72%);
    aspect-ratio: 1.58;
    padding: 28px;
    border: 1px solid rgb(255 255 255 / 16%);
    border-radius: 22px;
    box-shadow: 0 40px 90px rgb(0 0 0 / 55%);
    backdrop-filter: blur(18px);
  }

  .card-main {
    top: 27%;
    left: 15%;
    z-index: 3;
    background:
      linear-gradient(145deg, rgb(255 255 255 / 17%), transparent 55%),
      #151515;
    transform: rotateY(-12deg) rotateZ(-4deg);
  }

  .card-back {
    top: 12%;
    left: 30%;
    z-index: 1;
    justify-content: flex-start;
    background:
      linear-gradient(145deg, rgb(197 167 123 / 35%), transparent 60%),
      #211b14;
    color: rgb(255 255 255 / 48%);
    transform: rotateY(-13deg) rotateZ(8deg);
  }

  .card-front {
    top: 53%;
    left: 27%;
    z-index: 4;
    background:
      linear-gradient(135deg, rgb(255 255 255 / 18%), transparent 50%),
      rgb(30 30 30 / 82%);
    color: rgb(255 255 255 / 50%);
    transform: rotateY(-10deg) rotateZ(5deg);
  }

  .engraved-mark {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    margin-bottom: auto;
    border: 1px solid rgb(197 167 123 / 55%);
    border-radius: 50%;
    color: #c5a77b;
    font-family: Georgia, serif;
    font-size: 26px;
  }

  .card-main p {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  .card-main small {
    margin-top: 7px;
    color: rgb(255 255 255 / 43%);
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
  }

  .hero-glow-one {
    top: 10%;
    right: 5%;
    width: 360px;
    height: 360px;
    background: rgb(150 115 70 / 18%);
  }

  .hero-glow-two {
    bottom: 3%;
    left: 22%;
    width: 240px;
    height: 240px;
    background: rgb(255 255 255 / 7%);
  }

  .product-strip {
    padding: 42px clamp(24px, 5vw, 80px);
    border-top: 1px solid rgb(255 255 255 / 9%);
    background: #0c0c0c;
  }

  .product-strip > p {
    margin-bottom: 24px;
    color: rgb(255 255 255 / 35%);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .product-list {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 28px;
  }

  .product-list span {
    display: flex;
    align-items: center;
    gap: 28px;
    color: rgb(255 255 255 / 72%);
    font-size: clamp(15px, 1.5vw, 20px);
  }

  .product-list i {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #c5a77b;
  }
@keyframes fade-up {
  from {
    opacity: 0;
    transform: translateY(24px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes display-reveal {
  from {
    opacity: 0;
    transform: translateY(35px) scale(0.96);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.eyebrow,
.hero h1,
.hero-description,
.hero-actions {
  opacity: 0;
  animation: fade-up 800ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.eyebrow {
  animation-delay: 100ms;
}

.hero h1 {
  animation-delay: 200ms;
}

.hero-description {
  animation-delay: 350ms;
}

.hero-actions {
  animation-delay: 500ms;
}

.product-display {
  opacity: 0;
  animation: display-reveal 1100ms cubic-bezier(0.22, 1, 0.36, 1)
    350ms forwards;
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    scroll-behavior: auto !important;
    animation-duration: 1ms !important;
    animation-delay: 0ms !important;
    transition-duration: 1ms !important;
  }
}
  @media (max-width: 900px) {
    .site-header {
      grid-template-columns: 1fr auto;
    }

    nav {
      display: none;
    }

    .hero {
      grid-template-columns: 1fr;
      padding-top: 160px;
    }

    .product-display {
      min-height: 500px;
    }
  }

  @media (max-width: 560px) {
    .site-header {
  top: 10px;
  width: calc(100% - 20px);
  padding: 10px 10px 10px 14px;
}

    .brand {
      font-size: 14px;
    }

   .header-button {
  justify-self: end;
  padding: 12px 20px;
  border: 1px solid rgb(255 255 255 / 16%);
  border-radius: 999px;
  background: #f4f1eb;
  color: #111111;
  font-size: 12px;
  font-weight: 700;
  transition:
    transform 180ms ease,
    background 180ms ease;
}

.header-button:hover {
  background: #ffffff;
  transform: translateY(-1px);
}

    .hero {
      min-height: auto;
      padding: 145px 20px 60px;
    }

    h1 {
      font-size: clamp(50px, 16vw, 72px);
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .primary-button,
    .secondary-button {
      width: 100%;
    }

    .product-display {
      min-height: 400px;
    }

    .product-card {
      width: 75%;
      padding: 20px;
      border-radius: 17px;
    }

    .card-main {
      left: 5%;
    }

    .card-back {
      left: 20%;
    }

    .card-front {
      left: 18%;
    }

    .product-list i {
      display: none;
    }
  }
    </style>
  </body>
</html>

