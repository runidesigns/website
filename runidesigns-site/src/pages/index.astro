---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/home/Hero.astro";
import Services from "../components/home/Services.astro";
import FeaturedWork from "../components/home/FeaturedWork.astro";
import ContactCTA from "../components/home/ContactCTA.astro";

---

<MainLayout
  title="Runi Designs | Premium Custom Laser Engraving"
  description="Custom engraved products for businesses, celebrations, gifts, and meaningful moments."
>
  <main>
    <Hero />
    <Services />
    <FeaturedWork />
    <ContactCTA />
  </main>
</MainLayout>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    margin: 0;
    background: #ffffff;
    color: #111111;
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial,
      sans-serif;
    line-height: 1.5;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    min-height: 72px;
    padding: 0 5%;
    background: rgba(255, 255, 255, 0.9);
    border-bottom: 1px solid #eeeeee;
    backdrop-filter: blur(18px);
  }

  .brand {
    color: #111111;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 2rem;
  }

  nav a,
  .text-link {
    color: #333333;
    font-size: 0.95rem;
    text-decoration: none;
  }

  nav a:hover,
  .text-link:hover {
    color: #000000;
  }

  .header-button,
  .primary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #111111;
    color: #ffffff;
    font-weight: 600;
    text-decoration: none;
  }

  .header-button {
    padding: 0.7rem 1.1rem;
    font-size: 0.9rem;
  }

  .primary-button {
    padding: 0.95rem 1.4rem;
  }

  .eyebrow {
    margin-bottom: 1rem;
    color: #666666;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 950px;
    margin: 0 auto;
    font-size: clamp(3.3rem, 8vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.06em;
    line-height: 0.98;
  }

  .intro,
  .featured,
  .contact-section {
    max-width: 1400px;
    margin: 0 auto;
    padding: 7rem 5%;
  }

  h2 {
    max-width: 850px;
    margin: 0;
    font-size: clamp(2.5rem, 5vw, 4.8rem);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 3rem;
  }

  .service-card {
    min-height: 260px;
    padding: 2rem;
    border-radius: 24px;
    background: #f5f5f7;
  }

  .service-card h3 {
    margin: 0 0 1rem;
    font-size: 1.5rem;
  }

  .service-card p,
  .featured p,
  .contact-section > p {
    color: #666666;
    font-size: 1.05rem;
  }

  .featured {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    align-items: center;
    gap: 4rem;
  }

  .featured-placeholder {
    min-height: 600px;
    margin-top: 0;
  }

  .contact-section {
    text-align: center;
  }

  .contact-section h2,
  .contact-section > p {
    margin-right: auto;
    margin-left: auto;
  }

  .contact-section > p {
    max-width: 650px;
    margin-top: 1.5rem;
    margin-bottom: 2rem;
  }

  footer {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 5%;
    border-top: 1px solid #eeeeee;
    color: #777777;
    font-size: 0.85rem;
  }

  @media (max-width: 800px) {
    .site-header {
      min-height: 64px;
    }

    nav {
      display: none;
    }

    .header-button {
      padding: 0.6rem 0.9rem;
    }

    .service-grid,
    .featured {
      grid-template-columns: 1fr;
    }

    .featured-placeholder {
      min-height: 400px;
    }

    footer {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>