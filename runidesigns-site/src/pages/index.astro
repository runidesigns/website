---
const products = [
  "Metal Business Cards",
  "Bamboo Pens",
  "Leather Goods",
  "Stone Coasters",
  "Custom Glassware",
];
const showcaseProducts = [
  {
    category: "Business Essentials",
    title: "Metal Business Cards",
    description:
      "Premium engraved cards created to make your introduction feel distinctive, polished, and memorable.",
    image: "/images/products/metal-business-cards.jpg",
    alt: "Custom engraved metal business cards by Runi Designs",
  },
  {
    category: "Branded Products",
    title: "Bamboo Pens",
    description:
      "Custom engraved bamboo stylus pens designed for businesses, client gifts, events, and everyday promotion.",
    image: "/images/products/bamboo-pens.jpg",
    alt: "Custom engraved bamboo pens by Runi Designs",
  },
  {
    category: "Personalized Accessories",
    title: "Leather Keychains",
    description:
      "Personalized leather pieces crafted for gifts, celebrations, businesses, and meaningful everyday details.",
    image: "/images/products/leather-keychains.jpg",
    alt: "Personalized engraved leather keychains by Runi Designs",
  },
  {
    category: "Home & Celebrations",
    title: "Stone Coasters",
    description:
      "Custom engraved stone coasters made for homes, weddings, birthdays, special occasions, and branded gifts.",
    image: "/images/products/stone-coasters.jpg",
    alt: "Custom engraved stone coasters by Runi Designs",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <meta
      name="description"
      content="Runi Designs creates premium custom engraved products, business materials, gifts, and keepsakes."
    />

    <title>Runi Designs | Custom Engraving & Personalized Products</title>
  </head>

  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Runi Designs homepage">
        <span class="brand-mark">
          <img src="/images/runi-mark.svg" alt="" />
        </span>

        <span>Runi Designs</span>
      </a>

      <nav aria-label="Main navigation">
        <a href="#work">Our Work</a>
        <a href="#services">Services</a>
        <a href="#about">About</a>
      </nav>

      <a class="header-button" href="#quote">Request a Quote</a>
    </header>

    <main>
      <section class="hero">
        <div class="hero-glow hero-glow-one"></div>
        <div class="hero-glow hero-glow-two"></div>

        <div class="hero-content">
          <p class="eyebrow">Custom engraving and personalized design</p>

          <h1>
            Your vision.
            <span>Made unforgettable.</span>
          </h1>

          <p class="hero-description">
            Premium custom products created for businesses, celebrations,
            meaningful gifts, and moments worth remembering.
          </p>

          <div class="hero-actions">
            <a class="primary-button" href="#work">
              Explore Our Work
              <span aria-hidden="true">→</span>
            </a>

            <a class="secondary-button" href="#quote">
              Start a Project
            </a>
          </div>
        </div>

        <div class="product-display" aria-label="Runi Designs product display">
          <div class="display-orbit orbit-one"></div>
          <div class="display-orbit orbit-two"></div>

          <div class="product-card card-back">
            <span>Crafted</span>
          </div>

          <div class="product-card card-main">
            <div class="engraved-mark">R</div>
            <p>Runi Designs</p>
            <small>Designed to leave an impression.</small>
          </div>

          <div class="product-card card-front">
            <span>Personalized</span>
          </div>
        </div>
      </section>

      <section class="product-strip" id="work">
        <p>Made for every occasion</p>

        <div class="product-list">
          {
            products.map((product) => (
              <span>
                {product}
                <i aria-hidden="true"></i>
              </span>
            ))
          }
        </div>
      </section>
      <section class="showcase" id="services">
        <div class="showcase-heading">
    <p class="section-eyebrow">Selected work</p>

    <h2>Designed around your story.</h2>

    <p>
      From professional branding to meaningful gifts, every piece is
      personalized with care and made to leave a lasting impression.
    </p>
  </div>

  <div class="showcase-list">
    {
      showcaseProducts.map((product, index) => (
        <article
          class={`showcase-item ${index % 2 === 1 ? "showcase-item-reverse" : ""}`}
        >
          <div class="showcase-image">
            <img
              src={product.image}
              alt={product.alt}
              loading="lazy"
              width="1200"
              height="900"
            />
          </div>

          <div class="showcase-copy">
            <p class="product-category">{product.category}</p>
            <h3>{product.title}</h3>
            <p class="product-description">{product.description}</p>

            <a href="#quote" class="product-link">
              Request this product
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </article>
      ))
    }
  </div>
</section>
<section class="about-section" id="about">
  <div class="about-intro">
    <p class="section-eyebrow">The Runi difference</p>

    <h2>Personalized with purpose.</h2>

    <p class="about-description">
      Runi Designs transforms ideas, logos, names, and meaningful moments into
      custom pieces people remember. Every project receives thoughtful design,
      careful preparation, and attention to detail from concept to completion.
    </p>
  </div>

  <div class="about-grid">
    <article class="about-card">
      <span class="about-number">01</span>
      <h3>Thoughtful Design</h3>
      <p>
        Your artwork is carefully arranged for the product, material, and
        engraving area rather than simply placed onto a template.
      </p>
    </article>

    <article class="about-card">
      <span class="about-number">02</span>
      <h3>Made for You</h3>
      <p>
        From business branding to personal celebrations, every order is
        customized around your vision and occasion.
      </p>
    </article>

    <article class="about-card">
      <span class="about-number">03</span>
      <h3>Lasting Impressions</h3>
      <p>
        We create products that feel polished, memorable, and worthy of being
        shared, gifted, displayed, or used every day.
      </p>
    </article>
  </div>
</section>
    </main>

    <style>
  :root {
    font-family:
      Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #f7f7f5;
    background: #080808;
    font-synthesis: none;
    text-rendering: optimizeLegibility;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    min-width: 320px;
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 70% 25%, #27221c 0%, transparent 28%),
      #080808;
  }

  a {
    color: inherit;
    text-decoration: none;
  }
  
#work,
#services,
#about {
  scroll-margin-top: 110px;
}
  .site-header {
  position: fixed;
  z-index: 100;
  top: 16px;
  left: 50%;
  transform: translateX(-50%);
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  width: min(calc(100% - 32px), 1320px);
  padding: 12px 14px 12px 18px;
  border: 1px solid rgb(255 255 255 / 12%);
  border-radius: 999px;
  background: rgb(12 12 12 / 68%);
  box-shadow:
    0 16px 50px rgb(0 0 0 / 25%),
    inset 0 1px 0 rgb(255 255 255 / 5%);
  backdrop-filter: blur(24px) saturate(140%);
  -webkit-backdrop-filter: blur(24px) saturate(140%);
}

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    width: fit-content;
    font-size: 15px;
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .brand-mark {
  display: grid;
  place-items: center;
  width: 40px;
  height: 40px;
  overflow: hidden;
  border: 1px solid rgb(255 255 255 / 18%);
  border-radius: 50%;
  background: rgb(255 255 255 / 7%);
  backdrop-filter: blur(12px);
}

.brand-mark img {
  display: block;
  width: 26px;
  height: 26px;
  object-fit: contain;
}

  nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

nav a {
  padding: 10px 14px;
  border-radius: 999px;
  color: rgb(255 255 255 / 60%);
  font-size: 13px;
  font-weight: 550;
  white-space: nowrap;
  transition:
    color 180ms ease,
    background 180ms ease,
    transform 180ms ease;
}

nav a:hover {
  color: #ffffff;
  background: rgb(255 255 255 / 7%);
  transform: translateY(-1px);
}

  .header-button {
    justify-self: end;
    padding: 12px 20px;
    border: 1px solid rgb(255 255 255 / 16%);
    border-radius: 999px;
    background: #f4f1eb;
    color: #111111;
    font-size: 12px;
    font-weight: 700;
    transition:
      transform 180ms ease,
      background 180ms ease;
  }

  .header-button:hover {
    background: #ffffff;
    transform: translateY(-1px);
  }

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(380px, 0.85fr);
    align-items: center;
    gap: 40px;
    min-height: 100vh;
    padding: 140px clamp(24px, 7vw, 110px) 80px;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    max-width: 780px;
  }

  .eyebrow {
    margin-bottom: 24px;
    color: #c5a77b;
    font-size: 12px;
    font-weight: 650;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 850px;
    font-size: clamp(58px, 7.8vw, 122px);
    font-weight: 580;
    line-height: 0.88;
    letter-spacing: -0.075em;
  }

  h1 span {
    display: block;
    color: rgb(255 255 255 / 38%);
  }

  .hero-description {
    max-width: 620px;
    margin-top: 34px;
    color: rgb(255 255 255 / 59%);
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 40px;
  }

  .primary-button,
  .secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 24px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 650;
    transition:
      transform 200ms ease,
      background 200ms ease;
  }

  .primary-button {
    gap: 24px;
    background: #f4f1eb;
    color: #111111;
  }

  .primary-button:hover,
  .secondary-button:hover {
    transform: translateY(-3px);
  }

  .secondary-button {
    border: 1px solid rgb(255 255 255 / 16%);
    background: rgb(255 255 255 / 5%);
  }

  .product-display {
    position: relative;
    z-index: 2;
    min-height: 600px;
    perspective: 1200px;
  }

  .product-card {
    position: absolute;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    width: min(360px, 72%);
    aspect-ratio: 1.58;
    padding: 28px;
    border: 1px solid rgb(255 255 255 / 16%);
    border-radius: 22px;
    box-shadow: 0 40px 90px rgb(0 0 0 / 55%);
    backdrop-filter: blur(18px);
  }

  .card-main {
    top: 27%;
    left: 15%;
    z-index: 3;
    background:
      linear-gradient(145deg, rgb(255 255 255 / 17%), transparent 55%),
      #151515;
    transform: rotateY(-12deg) rotateZ(-4deg);
  }

  .card-back {
    top: 12%;
    left: 30%;
    z-index: 1;
    justify-content: flex-start;
    background:
      linear-gradient(145deg, rgb(197 167 123 / 35%), transparent 60%),
      #211b14;
    color: rgb(255 255 255 / 48%);
    transform: rotateY(-13deg) rotateZ(8deg);
  }

  .card-front {
    top: 53%;
    left: 27%;
    z-index: 4;
    background:
      linear-gradient(135deg, rgb(255 255 255 / 18%), transparent 50%),
      rgb(30 30 30 / 82%);
    color: rgb(255 255 255 / 50%);
    transform: rotateY(-10deg) rotateZ(5deg);
  }

  .engraved-mark {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    margin-bottom: auto;
    border: 1px solid rgb(197 167 123 / 55%);
    border-radius: 50%;
    color: #c5a77b;
    font-family: Georgia, serif;
    font-size: 26px;
  }

  .card-main p {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  .card-main small {
    margin-top: 7px;
    color: rgb(255 255 255 / 43%);
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
  }

  .hero-glow-one {
    top: 10%;
    right: 5%;
    width: 360px;
    height: 360px;
    background: rgb(150 115 70 / 18%);
  }

  .hero-glow-two {
    bottom: 3%;
    left: 22%;
    width: 240px;
    height: 240px;
    background: rgb(255 255 255 / 7%);
  }

  .product-strip {
    padding: 42px clamp(24px, 5vw, 80px);
    border-top: 1px solid rgb(255 255 255 / 9%);
    background: #0c0c0c;
  }

  .product-strip > p {
    margin-bottom: 24px;
    color: rgb(255 255 255 / 35%);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .product-list {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 28px;
  }

  .product-list span {
    display: flex;
    align-items: center;
    gap: 28px;
    color: rgb(255 255 255 / 72%);
    font-size: clamp(15px, 1.5vw, 20px);
  }

  .product-list i {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #c5a77b;
  }
@keyframes fade-up {
  from {
    opacity: 0;
    transform: translateY(24px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes display-reveal {
  from {
    opacity: 0;
    transform: translateY(35px) scale(0.96);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.eyebrow,
.hero h1,
.hero-description,
.hero-actions {
  opacity: 0;
  animation: fade-up 800ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.eyebrow {
  animation-delay: 100ms;
}

.hero h1 {
  animation-delay: 200ms;
}

.hero-description {
  animation-delay: 350ms;
}

.hero-actions {
  animation-delay: 500ms;
}

.product-display {
  opacity: 0;
  animation: display-reveal 1100ms cubic-bezier(0.22, 1, 0.36, 1)
    350ms forwards;
}
.showcase {
  padding: 140px clamp(24px, 7vw, 110px);
  background:
    radial-gradient(circle at 10% 20%, rgb(197 167 123 / 8%), transparent 28%),
    #080808;
}

.showcase-heading {
  max-width: 760px;
  margin: 0 auto 100px;
  text-align: center;
}

.section-eyebrow,
.product-category {
  color: #c5a77b;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.17em;
  text-transform: uppercase;
}

.showcase-heading h2 {
  margin-top: 20px;
  font-size: clamp(44px, 6vw, 82px);
  font-weight: 560;
  line-height: 0.98;
  letter-spacing: -0.065em;
}

.showcase-heading > p:last-child {
  max-width: 610px;
  margin: 28px auto 0;
  color: rgb(255 255 255 / 55%);
  font-size: 18px;
  line-height: 1.7;
}

.showcase-list {
  display: grid;
  gap: 130px;
  max-width: 1320px;
  margin: 0 auto;
}

.showcase-item {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.85fr);
  align-items: center;
  gap: clamp(50px, 8vw, 120px);
}

.showcase-item-reverse .showcase-image {
  order: 2;
}

.showcase-item-reverse .showcase-copy {
  order: 1;
}

.showcase-image {
  position: relative;
  overflow: hidden;
  aspect-ratio: 4 / 3;
  border: 1px solid rgb(255 255 255 / 10%);
  border-radius: 32px;
  background: #111111;
  box-shadow: 0 35px 90px rgb(0 0 0 / 40%);
}

.showcase-image::after {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    145deg,
    rgb(255 255 255 / 8%),
    transparent 42%
  );
  content: "";
  pointer-events: none;
}

.showcase-image img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
}

.showcase-item:hover .showcase-image img {
  transform: scale(1.035);
}

.showcase-copy {
  max-width: 500px;
}

.showcase-copy h3 {
  margin-top: 18px;
  font-size: clamp(38px, 4.5vw, 68px);
  font-weight: 560;
  line-height: 1;
  letter-spacing: -0.06em;
}

.product-description {
  margin-top: 25px;
  color: rgb(255 255 255 / 55%);
  font-size: 17px;
  line-height: 1.75;
}

.product-link {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  margin-top: 30px;
  padding-bottom: 7px;
  border-bottom: 1px solid rgb(197 167 123 / 50%);
  color: #f2eee8;
  font-size: 14px;
  font-weight: 650;
  transition:
    gap 180ms ease,
    border-color 180ms ease;
}

.product-link:hover {
  gap: 20px;
  border-color: #c5a77b;
}

.about-section {
  padding: 150px clamp(24px, 7vw, 110px);
  border-top: 1px solid rgb(255 255 255 / 8%);
  background:
    radial-gradient(
      circle at 80% 25%,
      rgb(197 167 123 / 10%),
      transparent 30%
    ),
    #0b0b0b;
}

.about-intro {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
  align-items: end;
  gap: clamp(50px, 9vw, 140px);
  max-width: 1320px;
  margin: 0 auto 90px;
}

.about-intro h2 {
  margin-top: 20px;
  font-size: clamp(48px, 6vw, 88px);
  font-weight: 560;
  line-height: 0.96;
  letter-spacing: -0.065em;
}

.about-description {
  color: rgb(255 255 255 / 56%);
  font-size: clamp(17px, 1.5vw, 20px);
  line-height: 1.75;
}

.about-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  max-width: 1320px;
  margin: 0 auto;
}

.about-card {
  min-height: 330px;
  padding: 34px;
  border: 1px solid rgb(255 255 255 / 10%);
  border-radius: 28px;
  background:
    linear-gradient(
      145deg,
      rgb(255 255 255 / 7%),
      transparent 55%
    ),
    rgb(255 255 255 / 3%);
  transition:
    transform 250ms ease,
    border-color 250ms ease,
    background 250ms ease;
}

.about-card:hover {
  border-color: rgb(197 167 123 / 35%);
  background:
    linear-gradient(
      145deg,
      rgb(197 167 123 / 12%),
      transparent 55%
    ),
    rgb(255 255 255 / 4%);
  transform: translateY(-7px);
}

.about-number {
  display: block;
  color: #c5a77b;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.15em;
}

.about-card h3 {
  margin-top: 100px;
  font-size: clamp(25px, 2.3vw, 34px);
  font-weight: 560;
  letter-spacing: -0.04em;
}

.about-card p {
  margin-top: 18px;
  color: rgb(255 255 255 / 50%);
  font-size: 15px;
  line-height: 1.7;
}
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    scroll-behavior: auto !important;
    animation-duration: 1ms !important;
    animation-delay: 0ms !important;
    transition-duration: 1ms !important;
  }
}
  @media (max-width: 900px) {
   .about-section {
  padding-top: 100px;
  padding-bottom: 100px;
}

.about-intro {
  grid-template-columns: 1fr;
  gap: 30px;
  margin-bottom: 60px;
}

.about-grid {
  grid-template-columns: 1fr;
}

.about-card {
  min-height: 280px;
}

.about-card h3 {
  margin-top: 70px;
}
  
    .site-header {
      grid-template-columns: 1fr auto;
    }

    nav {
      display: none;
    }

    .hero {
      grid-template-columns: 1fr;
      padding-top: 160px;
    }

    .product-display {
      min-height: 500px;
    }
    .showcase {
  padding-top: 100px;
  padding-bottom: 100px;
}

.showcase-heading {
  margin-bottom: 70px;
}

.showcase-list {
  gap: 90px;
}

.showcase-item {
  grid-template-columns: 1fr;
  gap: 36px;
}

.showcase-item-reverse .showcase-image,
.showcase-item-reverse .showcase-copy {
  order: initial;
}

.showcase-copy {
  max-width: 680px;
}
  }

  @media (max-width: 560px) {
    .about-section {
  padding: 80px 20px;
}

.about-intro {
  margin-bottom: 50px;
}

.about-card {
  min-height: 250px;
  padding: 26px;
  border-radius: 22px;
}

.about-card h3 {
  margin-top: 55px;
}

    .site-header {
  top: 10px;
  width: calc(100% - 20px);
  padding: 10px 10px 10px 14px;
}

    .brand {
      font-size: 14px;
    }

    .header-button {
      padding: 10px 14px;
      font-size: 11px;
    }

    .hero {
      min-height: auto;
      padding: 145px 20px 60px;
    }

    h1 {
      font-size: clamp(50px, 16vw, 72px);
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .primary-button,
    .secondary-button {
      width: 100%;
    }

    .product-display {
      min-height: 400px;
    }

    .product-card {
      width: 75%;
      padding: 20px;
      border-radius: 17px;
    }

    .card-main {
      left: 5%;
    }

    .card-back {
      left: 20%;
    }

    .card-front {
      left: 18%;
    }

    .product-list i {
      display: none;
    }
    .showcase {
  padding: 80px 20px;
