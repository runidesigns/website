---
const currentPath = Astro.url.pathname;

const isCurrentPage = (path) => currentPath === path;
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Runi Designs homepage">
    <span class="brand-mark">
      <img src="/images/runi-mark.svg" alt="" />
    </span>

    <span>Runi Designs</span>
  </a>

  <nav class="desktop-navigation" aria-label="Main navigation">
    <a
      href="/portfolio"
      aria-current={isCurrentPage("/portfolio") ? "page" : undefined}
    >
      Our Work
    </a>

    <a href="/#services">Services</a>

    <a
      href="/about"
      aria-current={isCurrentPage("/about") ? "page" : undefined}
    >
      About
    </a>

    <a
      href="/contact"
      aria-current={isCurrentPage("/contact") ? "page" : undefined}
    >
      Contact
    </a>
  </nav>

  <details class="mobile-menu">
    <summary aria-label="Open navigation menu">
      <span></span>
      <span></span>
      <span></span>
    </summary>

    <div class="mobile-menu-panel">
      <a href="/portfolio">Our Work</a>
      <a href="/#services">Services</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <a class="mobile-quote-link" href="/#quote">Request a Quote</a>
    </div>
  </details>

  <a class="header-button" href="/#quote">Request a Quote</a>
</header>

<style>
  .site-header {
    position: fixed;
    z-index: 1000;
    top: 16px;
    left: 50%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: min(calc(100% - 32px), 1320px);
    min-height: 72px;
    padding: 10px 12px 10px 16px;
    border: 1px solid rgb(255 255 255 / 13%);
    border-radius: 999px;
    background: rgb(10 10 10 / 82%);
    box-shadow: 0 18px 55px rgb(0 0 0 / 28%);
    backdrop-filter: blur(24px) saturate(140%);
    -webkit-backdrop-filter: blur(24px) saturate(140%);
    transform: translateX(-50%);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-decoration: none;
    white-space: nowrap;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    overflow: hidden;
    border: 1px solid rgb(255 255 255 / 18%);
    border-radius: 50%;
    background: rgb(255 255 255 / 8%);
  }

  .brand-mark img {
    display: block;
    width: 30px;
    height: 30px;
    object-fit: contain;
  }

  .desktop-navigation {
    display: flex;
    align-items: center;
    gap: clamp(24px, 3vw, 44px);
  }

  .desktop-navigation a {
    position: relative;
    color: rgb(255 255 255 / 58%);
    font-size: 13px;
    font-weight: 650;
    text-decoration: none;
    transition: color 180ms ease;
  }

  .desktop-navigation a:hover,
  .desktop-navigation a[aria-current="page"] {
    color: #ffffff;
  }

  .desktop-navigation a[aria-current="page"]::after {
    position: absolute;
    right: 0;
    bottom: -9px;
    left: 0;
    width: 4px;
    height: 4px;
    margin: auto;
    border-radius: 50%;
    background: #c5a77b;
    content: "";
  }

  .header-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    border-radius: 999px;
    background: #f4f1eb;
    color: #111111;
    font-size: 12px;
    font-weight: 750;
    text-decoration: none;
    transition:
      transform 180ms ease,
      background 180ms ease;
  }

  .header-button:hover {
    background: #ffffff;
    transform: translateY(-1px);
  }

  .mobile-menu {
    position: relative;
    display: none;
    margin-left: auto;
  }

  .mobile-menu summary {
    display: grid;
    gap: 5px;
    width: 46px;
    height: 46px;
    padding: 13px;
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: 50%;
    background: rgb(255 255 255 / 7%);
    cursor: pointer;
    list-style: none;
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu summary span {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 999px;
    background: #ffffff;
  }

  .mobile-menu-panel {
    position: absolute;
    top: calc(100% + 14px);
    right: 0;
    display: grid;
    width: min(310px, calc(100vw - 32px));
    padding: 12px;
    border: 1px solid rgb(255 255 255 / 13%);
    border-radius: 22px;
    background: rgb(12 12 12 / 96%);
    box-shadow: 0 25px 70px rgb(0 0 0 / 45%);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  .mobile-menu-panel a {
    padding: 15px 16px;
    border-radius: 13px;
    color: rgb(255 255 255 / 68%);
    font-size: 14px;
    font-weight: 650;
    text-decoration: none;
  }

  .mobile-menu-panel a:hover {
    background: rgb(255 255 255 / 7%);
    color: #ffffff;
  }

  .mobile-quote-link {
    display: none;
  }

  @media (max-width: 900px) {
    .desktop-navigation {
      display: none;
    }

    .mobile-menu {
      display: block;
    }

    .header-button {
      margin-left: 12px;
    }
  }

  @media (max-width: 560px) {
    .site-header {
      top: 10px;
      width: calc(100% - 20px);
      min-height: 64px;
      padding: 8px 8px 8px 12px;
    }

    .brand {
      font-size: 14px;
    }

    .brand-mark {
      width: 42px;
      height: 42px;
    }

    .header-button {
      display: none;
    }

    .mobile-quote-link {
      display: block;
      margin-top: 6px;
      background: #f4f1eb;
      color: #111111 !important;
      text-align: center;
    }
  }
</style>